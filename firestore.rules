rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /applications/{docId} {
      allow read:   if true;   // Admin reads via client SDK (password-gated in UI)
      allow create: if true;   // Users submit applications
      allow update: if true;   // Admin updates status
      allow delete: if false;
    }

    match /otps/{mobile} {
      allow read:   if true;
      allow write:  if true;
      allow delete: if true;
    }

    match /payments/{docId} {
      allow read:   if false;
      allow create: if true;
      allow update: if false;
      allow delete: if false;
    }

    match /bankConfig/{bankId} {
      allow read:  if true;
      allow write: if true;
    }
  }
}
